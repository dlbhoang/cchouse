{
  "name": "cchouse-antd",
  "version": "0.1.0",
  "private": true,
  "author": "cchouse",
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build && bun copy-files.ts",
    "build:turbo": "npx turbo build",
    "start": "next start .next/standalone/server.js",
    "lint": "biome lint --error-on-warnings ./src",
    "lint:fix": "npx @biomejs/biome lint --write ./src",
    "lint:turbo": "npx turbo lint",
    "type-check": "tsc --noEmit",
    "type-check:turbo": "npx turbo type-check",
    "test:e2e": "playwright test",
    "format": "prettier --write src",
    "up": "yarn upgrade-interactive",
    "up-latest": "yarn up --latest",
    "release": "cross-env standard-version",
    "push-release": "git push --follow-tags origin main",
    "clean": "rd /s /q .next node_modules out & del /q package-lock.json & echo 'Done cleanup' & npm i"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.23.0",
    "@ant-design/icons": "^5.2.4",
    "@changey/react-leaflet-markercluster": "^4.0.0-rc1",
