    "@types/react": "^18.3.20",
    "@types/react-speech-recognition": "^3.9.6",
    "cross-env": "^7.0.3",
    "eslint-config-next": "^14.2.26",
    "standard-version": "^9.5.0",
    "turbo": "^1.7.4",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=16.x.x"
  }
}